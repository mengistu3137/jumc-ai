{
  "expo": {
    "name": "JUMC AI Assistant",
    "slug": "jumc-ai-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "JUMC AI Assistant needs microphone access to capture voice commands from doctors."
      }
    },
    "android": {
      "package": "com.jumc.aiassistant",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow JUMC AI to access your microphone for voice commands."
        }
      ],
      "expo-asset"
    ]
  }
}
